# LUMIÈRE Environment Variables
# Copy to .env.local — never commit .env.local

# TxLINE (mainnet, Service Level 12 — free, real-time World Cup)
TXLINE_API_TOKEN=              # from activation script — long-lived, run scripts/activate.ts once
TXLINE_GUEST_JWT=              # seed value from activation — auto-renewed at runtime on 401
TXLINE_API_BASE=https://txline.txodds.com/api
TXLINE_API_ORIGIN=https://txline.txodds.com

# Solana (mainnet — used ONLY in scripts/activate.ts, never at runtime)
# Export from Phantom: Settings → Security & Privacy → Export Private Key
SOLANA_WALLET_PRIVATE_KEY=     # base58 encoded — NEVER commit this

# Supabase
NEXT_PUBLIC_SUPABASE_URL=      # from Supabase dashboard → Settings → API → Project URL
SUPABASE_SERVICE_KEY=          # from Supabase dashboard → Settings → API → service_role key (NOT anon key)

# AI explanation (pick one — Groq free tier recommended)
GROQ_API_KEY=                  # free at console.groq.com — use llama-3.1-8b-instant model
# OPENAI_API_KEY=              # alternative — gpt-4o-mini
# DEEPSEEK_API_KEY=            # alternative — deepseek-chat

# App
NEXT_PUBLIC_APP_URL=https://lumiere.vercel.app
NEXT_PUBLIC_DEMO_MATCH_ID=     # set after running scripts/find-demo-match.ts
