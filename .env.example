# LUMIÈRE Environment Variables
# Copy to .env.local — never commit .env.local

# TxLINE (mainnet, Service Level 12 — free, real-time World Cup)
TXLINE_API_TOKEN=              # from activation script — long-lived, run `npm run activate` once
TXLINE_GUEST_JWT=              # seed value from activation — auto-renewed at runtime on 401
TXLINE_API_BASE=https://txline.txodds.com/api
TXLINE_API_ORIGIN=https://txline.txodds.com

# Solana (mainnet — used ONLY in scripts/activate.ts, never at runtime)
# Export from Phantom: Settings -> Security & Privacy -> Export Private Key
SOLANA_WALLET_PRIVATE_KEY=     # base58 encoded — NEVER commit this

# Supabase
NEXT_PUBLIC_SUPABASE_URL=      # Supabase dashboard -> Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY= # Supabase dashboard -> Settings -> API -> anon/public key (client-side auth)
SUPABASE_SERVICE_KEY=          # Supabase dashboard -> Settings -> API -> service_role key (server only, bypasses RLS)

# Telegram bot (@BotFather)
TELEGRAM_BOT_TOKEN=            # from @BotFather
TELEGRAM_WEBHOOK_SECRET=       # any random string you choose — verified on incoming webhook calls
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME= # exact bot username without @; verified by npm run setup-telegram

# AI explanation (Groq free tier)
GROQ_API_KEY=                  # free at console.groq.com — uses llama-3.1-8b-instant

# App
NEXT_PUBLIC_APP_URL=https://lumiereworldcup.vercel.app
NEXT_PUBLIC_DEMO_MATCH_ID=     # set after running `npm run find-demo-match`

# Optional commercial integrations. Buttons remain hidden until enabled.
NEXT_PUBLIC_AFFILIATE_LINKS_ENABLED=false
SPORTYBET_AFFILIATE_URL=       # approved HTTPS template; use {code} where the booking code belongs
BET9JA_AFFILIATE_URL=
XBET_AFFILIATE_URL=
BET247_AFFILIATE_URL=
NEXT_PUBLIC_SHOCK_SPONSOR_NAME=
NEXT_PUBLIC_SHOCK_SPONSOR_URL=

# Protected anonymized B2B export: Authorization: Bearer <secret>
LUMIERE_DATA_EXPORT_SECRET=
CRON_SECRET=                   # protects /api/cron/resolve if scheduled externally
